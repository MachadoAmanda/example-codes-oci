# OCI Responses API
OCI_REGION=us-chicago-1
OCI_PROJECT_OCID=ocid1.generativeaiproject.oc1..<your_project_ocid>
OCI_GENAI_API_KEY=<your_oci_genai_api_key>

# MCP (DeepWiki)
OCI_MCP_SERVER_URL=https://mcp.deepwiki.com/mcp
OCI_MCP_ALLOWED_TOOLS=ask_question,read_wiki_structure,read_wiki_contents

# File Search (use an existing vector store id)
OCI_FILE_SEARCH_VECTOR_STORE_ID=vs_ord_<your_vector_store_id>

# Optional: local document path for upload/index demos
OCI_FILE_SEARCH_DOC_PATH=C:\Users\<user>\Documents\Sankhya\OCI-enterprise-AI-demo\build-ai-that-works-for-business.pdf

# Optional: set to user_data (recommended)
OCI_FILE_SEARCH_UPLOAD_PURPOSE=user_data

# Optional: show native tool traces in notebook output
OCI_TOOL_TRACE=true
